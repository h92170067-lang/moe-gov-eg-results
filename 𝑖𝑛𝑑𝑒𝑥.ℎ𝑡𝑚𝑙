<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>بوابة نتائج الامتحانات</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            text-align: center;
            padding: 30px;
        }
        .container {
            background-color: #fff;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            max-width: 600px;
            margin: auto;
        }
        .ministry-title {
            font-size: 18px;
            color: #7f8c8d;
            font-weight: bold;
            margin-bottom: 5px;
        }
        h2 {
            margin-top: 5px;
            color: #2c3e50;
        }
        .student-info {
            background-color: #ecf0f1;
            padding: 15px;
            border-radius: 5px;
            margin: 20px 0;
            text-align: right;
            display: none;
        }
        .student-info p {
            margin: 5px 0;
            font-size: 16px;
        }
        input[type="text"] {
            width: 180px;
            padding: 10px;
            margin: 15px 0;
            border: 1px solid #ccc;
            border-radius: 5px;
            text-align: center;
            font-size: 16px;
        }
        button {
            background-color: #27ae60;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
        }
        button:hover {
            background-color: #219150;
        }
        .result-table {
            width: 100%;
            margin-top: 20px;
            border-collapse: collapse;
            display: none;
        }
        .result-table th, .result-table td {
            border: 1px solid #ddd;
            padding: 10px;
            text-align: center;
        }
        .result-table th {
            background-color: #34495e;
            color: white;
        }
        .total-row {
            background-color: #f1c40f;
            font-weight: bold;
        }
        .non-added-header {
            background-color: #95a5a6 !important;
            color: white;
            font-weight: bold;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="ministry-title">وزارة التربية والتعليم</div>
    <h2>استعلام عن نتيجة الشهادة الإعدادية</h2>
    
    <input type="text" id="seatingNumber" placeholder="أدخل رقم الجلوس">
    <br>
    <button onclick="checkResult()">عرض النتيجة</button>

    <div class="student-info" id="studentInfo">
        <p><strong>الإدارة التعليمية:</strong> حلوان</p>
        <p><strong>المدرسة:</strong> المستقبل 3 الرسمية لغات</p>
        <p><strong>اسم الطالب:</strong> <span id="studentName"></span></p>
    </div>

    <table class="result-table" id="resultTable">
        <thead>
            <tr>
                <th>المادة</th>
                <th>الدرجة</th>
            </tr>
        </thead>
        <tbody id="tableBody">
            </tbody>
    </table>
</div>

<script>
// تهيئة عداد المحاولات في المتصفح لو مش موجود قبل كده
if (!localStorage.getItem('attemptsCount')) {
    localStorage.setItem('attemptsCount', '0');
}
if (!localStorage.getItem('usedGroupNumbers')) {
    localStorage.setItem('usedGroupNumbers', JSON.stringify([]));
}

function checkResult() {
    var seatingNum = document.getElementById("seatingNumber").value.trim();
    var table = document.getElementById("resultTable");
    var infoDiv = document.getElementById("studentInfo");
    var nameSpan = document.getElementById("studentName");
    var tbody = document.getElementById("tableBody");
    
    // سحب العداد والأرقام المستخدمة من الذاكرة
    var attempts = parseInt(localStorage.getItem('attemptsCount'));
    var usedGroupNumbers = JSON.parse(localStorage.getItem('usedGroupNumbers'));

    if(seatingNum === "") {
        alert("من فضلك أدخل رقم الجلوس أولاً");
        return;
    }

    // مجموعة الأرقام الخاصة بفرح أحمد سليمان
    var فرح_جروب = ["259080", "259081", "259082", "259083", "259084", "259085", "259086", "259089", "259090", "259091"];

    // 1. شرط إذا تم استهلاك رقمين جلوس مختلفين تماماً من قبل (الحد الأقصى للمحاولات الكلية)
    if (attempts >= 2) {
        alert("فشل المحاولة! لقد استهلكت أقصى عدد مسموح به لرؤية نتائج مختلفة.");
        table.style.display = "none";
        infoDiv.style.display = "none";
        return;
    }

    // 2. شرط تكرار رقم من مجموعة "فرح أحمد"
    if (فرح_جروب.includes(seatingNum)) {
        if (usedGroupNumbers.includes(seatingNum)) {
            alert("انتهت المحاولات المتوفرة لهذا الرقم!");
            table.style.display = "none";
            infoDiv.style.display = "none";
            return;
        }
    }

    // متغير لتخزين بيانات الطالب الحالي
    var studentData = null;

    // تشييك أرقام الجلوس وعرض البيانات المناسبة
    if (seatingNum === "259088") {
        // نتيجة كنزي محمد سيد بالدرجات والمجموع المحدث (257) برقم جلوس واحد فقط
        studentData = {
            name: "كنزي محمد سيد",
            scores: [
                {m: "اللغة العربية", d: "74"},
                {m: "الدراسات الاجتماعية", d: "57"},
                {m: "اللغة الإنجليزية", d: "38"},
                {m: "الرياضيات", d: "53"},
                {m: "العلوم", d: "35"},
                {m: "المجموع الكلي", d: "257", isTotal: true},
                {m: "مواد لا تضاف للمجموع", d: "", isHeader: true},
                {m: "لغة أجنبية أولى", d: "36"},
                {m: "لغة أجنبية ثانية", d: "35"},
                {m: "التربية الدينية", d: "38"},
                {m: "الحاسب الآلي", d: "15"},
                {m: "التربية الفنية", d: "34"}
            ]
        };
    } 
    else if (seatingNum === "259089") {
        // نتيجة كنزي عثمان عمر
        studentData = {
            name: "كنزي عثمان عمر",
            scores: [
                {m: "اللغة العربية", d: "70"},
                {m: "الدراسات الاجتماعية", d: "52"},
                {m: "اللغة الإنجليزية", d: "33"},
                {m: "الرياضيات", d: "50"},
                {m: "العلوم", d: "30"},
                {m: "المجموع الكلي", d: "235", isTotal: true},
                {m: "مواد لا تضاف للمجموع", d: "", isHeader: true},
                {m: "لغة أجنبية أولى", d: "32"},
                {m: "لغة أجنبية ثانية", d: "35"},
                {m: "التربية الدينية", d: "35"},
                {m: "الحاسب الآلي", d: "15"},
                {m: "التربية الفنية", d: "34"}
            ]
        };
    } 
    else if (seatingNum === "259087") {
        // نتيجة لجين اشرف عبد الله
        studentData = {
            name: "لجين أشرف عبد الله",
            scores: [
                {m: "اللغة العربية", d: "74"},
                {m: "الدراسات الاجتماعية", d: "56"},
                {m: "اللغة الإنجليزية", d: "36"},
                {m: "الرياضيات", d: "51"},
                {m: "العلوم", d: "35"},
                {m: "المجموع الكلي", d: "252", isTotal: true},
                {m: "مواد لا تضاف للمجموع", d: "", isHeader: true},
                {m: "لغة أجنبية أولى", d: "35"},
                {m: "لغة أجنبية ثانية", d: "35"},
                {m: "التربية الدينية", d: "36"},
                {m: "الحاسب الآلي", d: "15"},
                {m: "التربية الفنية", d: "34"}
            ]
        };
    } 
    else if (فرح_جروب.includes(seatingNum)) {
        // نتيجة فرح أحمد سليمان (للمجموعة المحددة)
        studentData = {
            name: "فرح أحمد سليمان",
            scores: [
                {m: "اللغة العربية", d: "70"},
                {m: "الدراسات الاجتماعية", d: "55"},
                {m: "اللغة الإنجليزية", d: "35"},
                {m: "الرياضيات", d: "50"},
                {m: "العلوم", d: "33"},
                {m: "المجموع الكلي", d: "246", isTotal: true},
                {m: "مواد لا تضاف للمجموع", d: "", isHeader: true},
                {m: "لغة أجنبية أولى", d: "35"},
                {m: "لغة أجنبية ثانية", d: "30"},
                {m: "التربية الدينية", d: "35"},
                {m: "الحاسب الآلي", d: "14"},
                {m: "التربية الفنية", d: "35"}
            ]
        };
        // حفظ الرقم لمنع تكراره
        usedGroupNumbers.push(seatingNum);
        localStorage.setItem('usedGroupNumbers', JSON.stringify(usedGroupNumbers));
    } 
    else {
        // أي رقم جلوس برة الحسبة خالص
        alert("رقم الجلوس غير صحيح!");
        table.style.display = "none";
        infoDiv.style.display = "none";
        return;
    }

    // زيادة عداد المحاولات الكلية الناجحة لتقييده برقمين بس
    attempts += 1;
    localStorage.setItem('attemptsCount', attempts.toString());

    // بناء الجدول وعرض البيانات ديناميكياً
    nameSpan.innerText = studentData.name;
    tbody.innerHTML = ""; // مسح الجدول القديم

    studentData.scores.forEach(function(row) {
        var tr = document.createElement("tr");
        if (row.isTotal) {
            tr.className = "total-row";
        }
        
        if (row.isHeader) {
            tr.innerHTML = `<td colspan="2" class="non-added-header">${row.m}</td>`;
        } else {
            tr.innerHTML = `<td>${row.m}</td><td>${row.d}</td>`;
        }
        tbody.appendChild(tr);
    });

    // إظهار اللوحات والجدول بعد النجاح
    infoDiv.style.display = "block";
    table.style.display = "table";
}
</script>

</body>
</html>
